APP_ENV=release
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
# 统一访问前缀：B 系统 nginx 原样反代时使用；前后端须一致。
# 可含多级路径，例如测试 /jzdd-dev-app/api/agent-flow；生产只改这一段即可。
# API 完整路径为 <BASE_PATH>/api/v1
BASE_PATH=/wgzcb-jzdd-dx/api/agent-flow
NEXT_PUBLIC_BASE_PATH=/wgzcb-jzdd-dx/api/agent-flow
DATABASE_URL=postgresql+psycopg://postgres:kT4wN8zY2pA@188.109.66.70:5432/agent_flow
DATABASE_ECHO=false
AUTO_CREATE_TABLES=false
TEMPORAL_ENABLED=false
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
ADMIN_USERNAME=platform_admin
ADMIN_PASSWORD=TaskFlow2026!Console
ADMIN_DISPLAY_NAME=Platform Admin
AUTH_SECRET_KEY=agent-flow-dev-secret
CORS_ORIGINS=http://188.109.66.66

# 打 web 镜像时须传入相同的 NEXT_PUBLIC_BASE_PATH（见 web/Dockerfile build-arg）。
NEXT_PUBLIC_API_BASE_URL=http://188.109.66.66/wgzcb-jzdd-dx/api/agent-flow/api/v1
INTERNAL_API_BASE_URL=http://api:8000/wgzcb-jzdd-dx/api/agent-flow/api/v1