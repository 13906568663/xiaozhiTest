APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
# api-only 常驻部署不对外反代，前缀置空即可（HTTP 接口走 /api/v1）
BASE_PATH=

# 数据库：指向同 compose 内的 pgvector 容器（服务名 db），凭据与 compose 中一致
DATABASE_URL=postgresql+psycopg://root:root@db:5432/agent_flow
DATABASE_ECHO=false
# 首次启动自动建表（本部署不接 Alembic 迁移流程）
AUTO_CREATE_TABLES=true

ADMIN_USERNAME=platform_admin
ADMIN_PASSWORD=change_this_admin_password
# 生产务必换成足够长的随机串
AUTH_SECRET_KEY=change_to_a_long_random_secret

# 全局兜底模型（可留空；DeepSeek 作为独立能力在下方单独配）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://cpa.aizhp.site/v1
DEFAULT_MODEL_NAME=gpt-5.2
# DeepSeek 官方 API key：能力注册表 code=deepseek 通过 api_key_env=DEEPSEEK_API_KEY 引用
DEEPSEEK_API_KEY=

# ===== 小智AI MCP 接入点 =====
XIAOZHI_MCP_ENABLED=true
# xiaozhi.me 控制台 -> 智能体 -> 配置角色，右下角复制
XIAOZHI_MCP_ENDPOINT=
# 由 scripts/bootstrap_xiaozhi_bot.py 在服务器数据库创建机器人后回填其 ID
XIAOZHI_CHATBOT_ID=
XIAOZHI_SYNC_TIMEOUT_SECONDS=20
XIAOZHI_SESSION_IDLE_MINUTES=30
XIAOZHI_REPLY_MAX_CHARS=800
# 常驻部署不建议对外开放 HTTP 调试入口
XIAOZHI_MCP_HTTP_ENABLED=false
XIAOZHI_MCP_HTTP_TOKEN=
