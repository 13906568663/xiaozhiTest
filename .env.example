APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
# 统一访问前缀：B 系统 nginx 原样反代我们的前后端时使用，所有接口/资源/文档
# 都挂在此前缀下。可含多级路径（如 /wgzcb-jzdd-dx/api/agent-flow）。置空则不加前缀。
BASE_PATH=/agent-flow
NEXT_PUBLIC_BASE_PATH=/agent-flow
DATABASE_URL=postgresql+psycopg://root:root@localhost:5432/agent_flow
DATABASE_ECHO=false
AUTO_CREATE_TABLES=true
TEMPORAL_ENABLED=false
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
ADMIN_USERNAME=platform_admin
ADMIN_PASSWORD=TaskFlow2026!Console
ADMIN_DISPLAY_NAME=Platform Admin
AUTH_SECRET_KEY=agent-flow-dev-secret
CORS_ORIGINS=http://localhost:3000
# 小智AI MCP 接入点（xiaozhi.me 控制台获取），启用后把平台能力暴露给小智语音终端
XIAOZHI_MCP_ENABLED=false
XIAOZHI_MCP_ENDPOINT=
XIAOZHI_CHATBOT_ID=
XIAOZHI_SYNC_TIMEOUT_SECONDS=20
XIAOZHI_SESSION_IDLE_MINUTES=30
XIAOZHI_REPLY_MAX_CHARS=800
# 可选：同一套工具挂成 streamable-http（{BASE_PATH}/xiaozhi/mcp）供其他 MCP 客户端/本地调试
XIAOZHI_MCP_HTTP_ENABLED=false
XIAOZHI_MCP_HTTP_TOKEN=
